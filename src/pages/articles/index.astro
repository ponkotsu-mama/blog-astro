---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime()
);
---
<BaseLayout title="記事一覧" activeNav="articles">
  <section class="section">
    <div class="section-inner">
      <h1 class="section-title">記事一覧</h1>
      <p class="section-subtitle">「あの頃の私へ」——過去の自分に語りかけるシリーズ</p>

      <div class="articles-grid">
        {posts.map((post) => (
          <div class="article-card">
            <div class="card-body">
              <span class="card-category">{post.data.category}</span>
              <h3 class="card-title">
                <a href={`/articles/${post.id}`}>{post.data.title}</a>
              </h3>
              <p class="card-excerpt">{post.data.excerpt}</p>
              <div class="card-meta">{post.data.date}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
