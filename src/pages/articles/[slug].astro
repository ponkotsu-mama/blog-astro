---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, category, message, prevSlug, prevTitle, nextSlug, nextTitle } = post.data;
---
<BaseLayout title={title} activeNav="articles">
  <main class="article-layout">
    <article>
      <header class="article-header">
        <span class="card-category">{category}</span>
        <h1>{title}</h1>
        <div class="article-meta">{date}</div>
      </header>

      <div class="article-body">
        <Content />

        {(prevSlug || nextSlug) && (
          <div style="margin-top:32px; display:flex; flex-direction:column; gap:8px;">
            {prevSlug && (
              <a href={`/articles/${prevSlug}`} style="color:var(--color-primary);">
                ← 前の記事「{prevTitle}」
              </a>
            )}
            {nextSlug && (
              <a href={`/articles/${nextSlug}`} style="color:var(--color-primary); font-weight:700;">
                → 次の記事「{nextTitle}」へ
              </a>
            )}
          </div>
        )}

        {message && (
          <div style="margin-top:48px; background:var(--color-primary-pale); border-left:4px solid var(--color-primary); border-radius:0 var(--radius) var(--radius) 0; padding:24px 28px;">
            <p style="font-size:0.8rem; font-weight:700; color:var(--color-primary); margin-bottom:12px; letter-spacing:0.05em;">今の私から、あの頃の私へ</p>
            {message.trim().split('\n\n').map((para: string) => (
              <p set:html={para.replace(/\n/g, '<br>')} />
            ))}
          </div>
        )}
      </div>
    </article>

    <div style="margin-top:48px; padding-top:32px; border-top:1px solid var(--color-border);">
      <a href="/articles" style="color:var(--color-text-light); font-size:0.9rem;">← 記事一覧に戻る</a>
    </div>
  </main>
</BaseLayout>
